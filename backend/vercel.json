{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "routes/**",
          "controllers/**",
          "models/**",
          "lib/**",
          ".env"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://apisbltd.vercel.app/api/:path*"
    }
  ]
}
